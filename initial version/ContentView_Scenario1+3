                    .font(.subheadline.bold())
                    .foregroundColor(.white)
                    .strikethrough(isDone)
                
                Spacer()
                
                Image(systemName: isDone ? "checkmark.circle.fill" : "circle")
                    .foregroundColor(.white)
            }
            .padding(12)
            .background(Theme.sage)
            .clipShape(RoundedRectangle(cornerRadius: 14))
        }
        .buttonStyle(.plain)
    }
}

